  "scenes": [
    {
      "id": "regalia:scene/atlas-of-borrowed-winds/unbound-page",
      "role": "chapter",
      "defaults": {
        "background": {
          "asset": "assets/art/arcs/atlas-of-borrowed-winds/backgrounds/chapter_01_unbound_page.jpg",
          "fit": "cover"
        },
        "characters": []
      },
      "frames": [
        {
          "id": "the-road-that-rose",
          "title": "The Unbound Page",
          "paragraphs": [
            "The caravan is safe, but an oasis is moving across the desert: palms, wells, gardens, and soil all pulled from their home. Ilyun cannot undo a command once the atlas has acted.",
            "Nahla follows the new road to find who lost the water. A Compass Roc, confused by the changed winds, blocks the path ahead."
          ],
          "semanticLabel": "A caravan stands safe beneath spinning wind plates while a distant oasis rises from the desert.",
          "actionLabel": "Trace the cost"
        }
      ]
    },
    {
      "id": "regalia:scene/atlas-of-borrowed-winds/missing-water",
      "role": "chapter",
      "defaults": {
        "background": {
          "asset": "assets/art/arcs/atlas-of-borrowed-winds/backgrounds/chapter_02_missing_water.jpg",
          "fit": "cover"
        },
        "characters": []
      },
      "frames": [
        {
          "id": "the-dry-basin",
          "title": "The Missing Water",
          "paragraphs": [
            "Nahla finds Anbar beside an empty basin. The town’s wells are dry because the atlas treated its oasis as if it belonged to no one.",
            "Samir, a caravan guide, shows Nahla the old channels and the people who remember them. Together they begin reopening the water, but a Dryroot Wyrm guards the main gate."
          ],
          "semanticLabel": "The exposed roots of a vanished oasis surround a dry town whose official milestones deny the water ever existed.",
          "actionLabel": "Listen to Anbar"
        }
      ]
    },
    {
      "id": "regalia:scene/atlas-of-borrowed-winds/grammar-of-borders",
      "role": "chapter",
      "defaults": {
        "background": {
          "asset": "assets/art/arcs/atlas-of-borrowed-winds/backgrounds/chapter_03_grammar_of_borders.jpg",
          "fit": "cover"
        },
        "characters": []
      },
      "frames": [
        {
          "id": "a-language-of-consequence",
          "title": "Grammar of Borders",
          "paragraphs": [
            "Ilyun teaches Nahla the question the royal maps ignore: who will this change affect? Her first command saved the caravan but forgot Anbar.",
            "Four towns need one road that they can share by season. The palace’s Gilded Arbiter arrives to shut them down because the road is not under royal control."
          ],
          "semanticLabel": "Four routes converge on a lapis contract court beneath constellations aligned with every settlement.",
