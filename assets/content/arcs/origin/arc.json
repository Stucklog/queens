  "scenes": [
    {
      "id": "regalia:scene/origin/clovermead",
      "role": "chapter",
      "pages": [
        {
          "title": "Asterfall Vale",
          "paragraphs": [
            "The Regalia fell here. Its first jewel points the knight toward an old shrine beyond the farms.",
            "The Starfall Stag stands in front of the shrine. It has driven thorn-creatures into the fields and will not let anyone pass. The knight raises their shield and walks forward."
          ],
          "semanticLabel": "The knight approaches an old shrine in Asterfall Vale, guarded by the Starfall Stag.",
          "actionLabel": "Enter Asterfall"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_clovermead.webp"
    },
    {
      "id": "regalia:scene/origin/whisperwood",
      "role": "chapter",
      "pages": [
        {
          "title": "Myrrhveil Wilds",
          "paragraphs": [
            "The first jewel reveals a narrow path into Myrrhveil Wilds. Roots close behind the knight, leaving only one way forward.",
            "At the heart of the forest, the Elderroot Wyrm coils around the oldest tree. The second jewel glows when it sees the tree, but the wyrm tightens its grip."
          ],
          "semanticLabel": "The knight enters Myrrhveil Wilds, where the Elderroot Wyrm guards the second jewel’s power.",
          "actionLabel": "Enter Myrrhveil"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_whisperwood.webp"
    },
    {
      "id": "regalia:scene/origin/windmill-heights",
      "role": "chapter",
      "pages": [
        {
          "title": "Skyglass Reach",
          "paragraphs": [
            "An ancient wind gate carries the knight to Skyglass Reach. The floating islands are linked by glass bridges that the storm keeps breaking apart.",
            "The Tempest Roc has trapped the realm’s winds inside a cage of lightning. The third jewel will stay dark until the knight reaches it."
          ],
          "semanticLabel": "The knight crosses broken bridges beneath the storm around Skyglass Reach.",
          "actionLabel": "Enter Skyglass"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_windmill_heights.webp"
    },
    {
      "id": "regalia:scene/origin/sunken-cloister",
      "role": "chapter",
      "pages": [
        {
          "title": "Nacre Basilica",
          "paragraphs": [
            "A stairway from Skyglass leads beneath the sea to Nacre Basilica, a flooded city of tiled halls and bell towers.",
            "The Abyssal Bellkeeper pulls the rope in the tallest tower. Each swing raises the tide, and the fourth jewel begins to stir. The knight heads into the water."
          ],
          "semanticLabel": "The knight enters flooded Nacre Basilica while the Abyssal Bellkeeper raises the tide.",
          "actionLabel": "Enter Nacre Basilica"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_sunken_cloister.webp"
    },
    {
      "id": "regalia:scene/origin/emberbell-caverns",
      "role": "chapter",
      "pages": [
        {
          "title": "Pyreheart Caldera",
          "paragraphs": [
            "The restored Regalia opens a sealed furnace door. Beyond it lies Pyreheart Caldera, an old forge built inside a volcano.",
            "The fifth jewel was made at the central anvil. The Cindermaw Behemoth has made its den there and blocks the way."
          ],
          "semanticLabel": "The knight enters the volcanic forge of Pyreheart Caldera, where the Cindermaw Behemoth blocks the anvil.",
          "actionLabel": "Enter Pyreheart"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_emberbell_caverns.webp"
    },
    {
      "id": "regalia:scene/origin/goblin-underkeep",
      "role": "chapter",
      "pages": [
        {
          "title": "Brasswake Arsenal",
          "paragraphs": [
            "A rail leads from the forge into Brasswake Arsenal, an abandoned factory full of brass sentries.",
            "The Gilded War Colossus guards the power for the sixth jewel and the only lift to the upper realms. It sees the knight as an intruder and lowers its spear."
          ],
          "semanticLabel": "The knight reaches Brasswake Arsenal, where the Gilded War Colossus guards the lift to the upper realms.",
          "actionLabel": "Enter Brasswake"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_goblin_underkeep.webp"
    },
    {
      "id": "regalia:scene/origin/moonlit-catacombs",
      "role": "chapter",
      "pages": [
        {
          "title": "Pale Moon Necropolis",
          "paragraphs": [
            "The lift opens in the tombs of seven former queens. As the knight walks past them, the Regalia grows heavy and their voices begin to question the stranger wearing it.",
            "The Hollow Star turns their doubt into the Sevenfold Wraith. It guards the seventh jewel and orders the knight to kneel. The knight refuses."
          ],
          "semanticLabel": "The knight faces the Sevenfold Wraith in the tombs of the former queens.",
          "actionLabel": "Enter the Necropolis"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_moonlit_catacombs.webp"
    },
    {
      "id": "regalia:scene/origin/crownspire",
      "role": "chapter",
      "pages": [
        {
          "title": "Empyrean Citadel",
          "paragraphs": [
            "With seven jewels restored, the Regalia opens the cloud gate to the Empyrean Citadel. The city is empty and silent.",
            "In the throne hall, the knight finds the Queen trapped behind a wall of darkness. The Hollow Star hangs above her, keeping the eighth jewel dark."
          ],
          "semanticLabel": "The knight reaches the empty citadel, where the Hollow Star holds the Queen behind darkness.",
          "actionLabel": "Enter the Citadel"
        }
      ],
      "artAsset": "assets/art/backgrounds/chapter_crownspire_final.png"
    },
    {
      "id": "regalia:scene/origin/finale",
      "role": "finale",
      "defaults": {
        "background": {
          "asset": "assets/art/backgrounds/story_finale.webp",
