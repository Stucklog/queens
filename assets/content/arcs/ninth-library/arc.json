      "frames": [
        {
          "id": "chapter-1-arrival",
          "title": "A Card from a Shadow",
          "paragraphs": [
            "Alis's Shadow leads Oriel through closed reading rooms while the catalog card rearranges shelf marks into a route below the university. Oriel must restore the card's broken sequence before the night porter discovers them.",
            "At the final index, a many-tined sentinel called The Index Hart charges along every false branch of the catalog. Oriel corners it with the one call number the university erased, and the hidden stair opens beneath its hooves."
          ],
          "semanticLabel": "Oriel and Alis's Shadow face an antlered index sentinel among tilting shelves and red catalog lights.",
          "actionLabel": "Open the hidden stair"
        }
      ]
    },
