          "frames": [
            {
              "id": "stolen-dawn",
              "title": "The Stolen Dawn",
              "paragraphs": [
                "The eight jewels of the Queen’s Regalia keep the roads open and daylight shining across the eight realms.",
                "Then a dark star appears above the Empyrean Citadel. It traps the Queen and covers the kingdom in darkness."
              ],
              "semanticLabel": "The Hollow Star blocks the sun above the Empyrean Citadel.",
              "actionLabel": "See what happened"
            },
            {
              "id": "falling-crown",
              "title": "The Falling Crown",
              "paragraphs": [
                "Before the darkness closes around her, the Queen sends the Regalia away. The crown falls into Asterfall Vale, and its jewels go dark.",
                "A traveling knight finds it in a meadow. When they touch the crown, they see the Queen trapped in the citadel."
              ],
              "semanticLabel": "The Regalia falls from the darkened citadel and lands near a knight.",
              "actionLabel": "Follow the crown"
            },
            {
              "id": "knights-choice",
              "title": "The Knight’s Choice",
              "paragraphs": [
                "The vision shows one clear path: restore the eight jewels, defeat the Hollow Star, and free the Queen.",
                "The knight puts on the crown and walks toward the first darkened road. The first jewel gives a small spark."
              ],
              "semanticLabel": "The knight puts on the darkened Regalia and begins the journey.",
              "actionLabel": "Begin the journey"
            }
          ]
        }
      }
