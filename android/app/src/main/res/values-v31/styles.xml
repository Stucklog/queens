<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ uses a dedicated system splash background. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#151D3B</item>
        <item name="android:statusBarColor">#151D3B</item>
        <item name="android:navigationBarColor">#151D3B</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
